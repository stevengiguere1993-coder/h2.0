  "conditional_logic": {
    "_doc": "Logique conditionnelle appliquée par le service avant substitution.",
    "refi_equite_negative": {
      "trigger": "Si l'équité dégagée du meilleur scénario refi est < 0",
      "actions": [
        "label_callout_refi := 'Remboursement du partenaire'",
        "valeur_callout_refi := pourcentage (ex. 'Jusqu’à 90%') au lieu d'un montant $",
        "Le service substitue 'Jusqu’à \\n 347 373$' (TextBox 18) par 'Jusqu’à \\n {valeur_callout_refi}' et le libellé TextBox 29 par 'Remboursement du partenaire'"
      ]
    },
    "taxes_scolaires_incluses": {
      "trigger": "Si analysis.taxes_scolaires == 0 (ou None)",
      "actions": [
        "Le libellé reste 'Taxes municipales (inclus scolaire)' (défaut template)",
        "Sinon, libellé devient 'Taxes municipales' (slide 7 cell 3,3)"
      ]
    }
