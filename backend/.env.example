# Environment
ENV=development
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/construction_db

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# S3 Storage (for future use)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# QuickBooks Integration (for future use)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENV=sandbox

# Anthropic (SEO content, validateurs — hors extraction lead)
ANTHROPIC_API_KEY=

# Gemini (Google AI Studio) — extraction des leads immobiliers.
# Tier gratuit : 1500 req/jour. Générer une clé sur :
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Override optionnel du modèle Gemini pour l'extraction lead.
# Défaut : gemini-2.0-flash
# LEAD_EXTRACTION_MODEL=gemini-2.0-flash
